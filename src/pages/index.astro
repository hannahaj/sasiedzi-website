    .btn-pakiet { background: #D8A039; color: #14213D; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 16px; padding: 15px 32px; border-radius: 999px; transition: background 0.2s ease; }
    .btn-pakiet:hover { background: #E5B155; color: #14213D; }

    /* Cennik */
    .section-cennik { padding: 0 64px 96px; display: flex; flex-direction: column; align-items: center; gap: 40px; }
    .cennik-table { max-width: 1140px; width: 100%; background: #FFFFFF; border: 1px solid #EADFCC; border-radius: 20px; overflow: hidden; }
    .cennik-row { display: grid; grid-template-columns: 1.1fr 2fr 0.8fr; gap: 0; padding: 18px 28px; font-size: 15px; color: #14213D; }
    .cennik-row.header { border-bottom: 1px solid #EADFCC; font-family: 'Poppins', sans-serif; font-weight: 700; }
    .cennik-row.border { border-bottom: 1px solid #F0E7D6; }
    .cennik-row.featured { background: #FAF3E8; }
    .cennik-row .name { font-weight: 700; }
    .cennik-row .desc { color: #5A6478; }
    .cennik-row .price { text-align: right; font-weight: 700; }
    .cennik-row .price.featured { color: #B07E22; }

    /* Projekty */
    .section-projekty { background: #FFFFFF; border-top: 1px solid #EADFCC; border-bottom: 1px solid #EADFCC; padding: 96px 64px; display: flex; flex-direction: column; align-items: center; gap: 48px; }
    .section-projekty h3.section-title { margin: 0; font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 38px; color: #14213D; }
    .projekt-card { display: flex; flex-direction: column; gap: 14px; }
    .projekt-img { width: 100%; aspect-ratio: 4 / 3; border-radius: 16px; overflow: hidden; }
    .projekt-img img { width: 100%; height: 100%; object-fit: cover; object-position: left top; display: block; transition: transform 0.3s ease; }
    .projekt-card:hover .projekt-img img { transform: scale(1.03); }
    .projekt-card h3 { margin: 0; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 18px; }
    .projekt-card p { margin: 0; font-size: 14px; color: #5A6478; }

    /* FAQ */
    .section-faq { padding: 96px 64px; display: flex; flex-direction: column; align-items: center; gap: 40px; }
    .faq-list { max-width: 820px; width: 100%; display: flex; flex-direction: column; gap: 14px; }
    details { background: #FFFFFF; border: 1px solid #EADFCC; border-radius: 16px; padding: 20px 26px; }
    summary { font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 16px; color: #14213D; cursor: pointer; list-style: none; }
    summary::-webkit-details-marker { display: none; }
    summary::after { content: '+'; float: right; font-size: 20px; font-weight: 400; color: #D8A039; }
    details[open] summary::after { content: '−'; }
    details p { margin: 12px 0 0; font-size: 15px; line-height: 1.6; color: #5A6478; }

    /* Kontakt */
    .section-kontakt { background: #14213D; padding: 96px 64px; display: flex; justify-content: center; }
    .kontakt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; max-width: 1140px; width: 100%; align-items: center; }
    .kontakt-info { display: flex; flex-direction: column; gap: 24px; }
    .kontakt-info h2 { margin: 0; font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 40px; color: #FAF3E8; line-height: 1.2; }
    .kontakt-info .tagline { margin: 0; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 20px; color: #FAF3E8; line-height: 1.3; }
    .kontakt-info .lead { margin: 0; font-size: 17px; line-height: 1.6; color: #B9C0D0; }
    .kontakt-contact { display: flex; flex-direction: column; gap: 8px; }
    .kontakt-contact a { color: #FAF3E8; font-weight: 700; font-size: 16px; }
    .kontakt-contact a:hover { color: #D8A039; }
    .kontakt-contact span { color: #B9C0D0; font-size: 15px; }
    .kontakt-form { background: #FAF3E8; border-radius: 20px; padding: 40px; display: flex; flex-direction: column; gap: 18px; }
    .form-group { display: flex; flex-direction: column; gap: 7px; }
    .form-group label { font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 14px; color: #14213D; }
    .form-group input, .form-group textarea { border: 1.5px solid #E0D4BE; border-radius: 12px; padding: 13px 16px; font-family: 'Manrope', sans-serif; font-size: 15px; color: #14213D; background: #FFFFFF; outline: none; width: 100%; transition: border-color 0.2s ease; }
    .form-group input:focus, .form-group textarea:focus { border-color: #D8A039; }
    .form-group textarea { resize: vertical; }
    .form-success { background: #14213D; color: #FAF3E8; border-radius: 12px; padding: 14px 18px; font-size: 15px; text-align: center; display: none; }
    .form-success.visible { display: block; }
    .btn-submit { background: #D8A039; color: #14213D; border: none; cursor: pointer; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 16px; padding: 16px 32px; border-radius: 999px; transition: background 0.2s ease; }
    .btn-submit:hover { background: #E5B155; }

    /* Footer */
    footer { background: #0E1830; padding: 28px 64px; display: flex; align-items: center; justify-content: space-between; }
    .footer-logo { display: flex; align-items: center; gap: 10px; }
    .footer-logo-text { font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 16px; color: #FAF3E8; }
    .footer-copy { font-size: 13.5px; color: #7A849B; }

    /* Responsywność */
    @media (max-width: 900px) {
      .nav { padding: 18px 24px; }
      .nav-links { display: none; }
      .nav-toggle { display: block; }
      .nav-links.open { display: flex; flex-direction: column; position: absolute; top: 70px; left: 0; right: 0; background: #14213D; padding: 20px 24px; gap: 20px; z-index: 100; }
      .hero { padding: 64px 24px 0; }
      .hero h1 { font-size: 36px; }
      .hero-lead { font-size: 16px; }
      .hero-cta { flex-direction: column; }
      .grid-3 { grid-template-columns: 1fr; }
      .section-uslugi, .section-jak, .section-pakiet, .section-cennik, .section-projekty, .section-faq { padding-left: 24px; padding-right: 24px; }
      .pakiet-box { padding: 48px 28px; }
      .cennik-row { grid-template-columns: 1fr 1fr; }
      .cennik-row .desc { display: none; }
      .kontakt-grid { grid-template-columns: 1fr; gap: 40px; }
      .section-kontakt { padding: 64px 24px; }
      footer { padding: 24px; flex-direction: column; gap: 12px; text-align: center; }
