    .nav-links a:hover { color: #D8A039; }
    .btn-pill { background: #D8A039; color: #14213D !important; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 15px; padding: 12px 24px; border-radius: 999px; transition: background 0.2s ease; }
    .btn-pill:hover { background: #E5B155 !important; color: #14213D !important; }
    .nav-toggle { display: none; background: none; border: none; cursor: pointer; padding: 8px; }

