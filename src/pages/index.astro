  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: #FAF3E8; font-family: 'Manrope', sans-serif; color: #14213D; }
    a { color: inherit; text-decoration: none; }
    a:hover { color: #D8A039; }
    img { max-width: 100%; }

    @keyframes okno {
      0%, 55%, 100% { opacity: 0; }
      8%, 40% { opacity: 1; }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(26px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes rise {
      from { opacity: 0; transform: translateY(60px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes twinkle {
      0%, 100% { opacity: 0.15; }
      50% { opacity: 0.8; }
    }
    @keyframes knock {
      0%, 76%, 100% { transform: rotate(0deg) scale(1); }
      79% { transform: rotate(-6deg) scale(1.05); }
      84% { transform: rotate(6deg) scale(1.05); }
      89% { transform: rotate(-4deg) scale(1.03); }
      94% { transform: rotate(2deg) scale(1.01); }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation: none !important; transition: none !important; }
    }

    /* Nav */
    .nav { background: #14213D; padding: 22px 64px; display: flex; align-items: center; justify-content: space-between; }
