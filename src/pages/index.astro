    .hero h1 { margin: 0; font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 58px; line-height: 1.12; color: #FAF3E8; animation: fadeUp 0.7s ease-out both; }
    .hero h1 span { color: #D8A039; }
    .hero-lead { margin: 0; font-size: 19px; line-height: 1.6; color: #B9C0D0; max-width: 560px; animation: fadeUp 0.7s ease-out 0.15s both; }
    .hero-cta { display: flex; gap: 16px; align-items: center; animation: fadeUp 0.7s ease-out 0.3s both; }
    .btn-hero { display: inline-block; background: #D8A039; color: #14213D; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 17px; padding: 16px 34px; border-radius: 999px; animation: knock 7s ease-in-out 2s infinite; transform-origin: 50% 100%; transition: background 0.2s ease; }
    .btn-hero:hover { background: #E5B155; color: #14213D; }
    .btn-ghost { color: #FAF3E8; font-weight: 700; font-size: 16px; padding: 16px 10px; border-bottom: 2px solid #D8A039; }
    .btn-ghost:hover { color: #D8A039; }
    .skyline { display: block; width: 100%; margin-top: 72px; }

    /* Usługi */
    .section-uslugi { padding: 96px 64px; display: flex; flex-direction: column; align-items: center; gap: 48px; }
    .section-header { max-width: 640px; text-align: center; display: flex; flex-direction: column; gap: 14px; }
    .section-header h2 { margin: 0; font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 38px; color: #14213D; }
    .section-header p { margin: 0; font-size: 17px; line-height: 1.6; color: #5A6478; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; max-width: 1140px; width: 100%; }
    .card { background: #FFFFFF; border: 1px solid #EADFCC; border-radius: 20px; padding: 34px 30px; display: flex; flex-direction: column; gap: 14px; transition: transform 0.25s ease, box-shadow 0.25s ease; }
    .card:hover { transform: translateY(-6px); box-shadow: 0 12px 28px rgba(20,33,61,0.12); }
    .card h3 { margin: 0; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 21px; }
    .card p { margin: 0; font-size: 15px; line-height: 1.6; color: #5A6478; }

    /* Jak działamy */
    .section-jak { padding: 0 64px 96px; display: flex; flex-direction: column; align-items: center; gap: 48px; }
    .section-jak h3.section-title { margin: 0; font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 38px; color: #14213D; }
    .krok { display: flex; flex-direction: column; gap: 12px; padding: 8px 12px; }
    .krok-num { width: 48px; height: 48px; border-radius: 14px; background: #D8A039; display: flex; align-items: center; justify-content: center; font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 20px; color: #14213D; }
    .krok h3 { margin: 0; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 19px; }
    .krok p { margin: 0; font-size: 15px; line-height: 1.6; color: #5A6478; }

    /* Pakiet */
    .section-pakiet { padding: 0 64px 96px; display: flex; justify-content: center; }
    .pakiet-box { background: #14213D; border-radius: 24px; padding: 72px 64px; max-width: 1140px; width: 100%; display: flex; flex-direction: column; align-items: center; gap: 20px; text-align: center; }
    .pakiet-box h2 { margin: 0; font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 36px; color: #FAF3E8; }
